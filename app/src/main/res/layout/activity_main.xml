<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="48dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="פיקוד העורף לילדים חמודים 🦄"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="בודק הרשאות..."
            android:textColor="#AAAAAA"
            android:textSize="17sp"
            android:layout_marginBottom="28dp" />

        <!-- Service controls -->
        <Button android:id="@+id/btn_permission"
            android:layout_width="340dp" android:layout_height="wrap_content"
            android:text="אשר הרשאת שכבת-על" android:textSize="16sp"
            android:backgroundTint="#AA0000" android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <Button android:id="@+id/btn_service"
            android:layout_width="340dp" android:layout_height="wrap_content"
            android:text="הפעל שירות רקע" android:textSize="16sp"
            android:backgroundTint="#004400" android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <Button android:id="@+id/btn_settings"
            android:layout_width="340dp" android:layout_height="wrap_content"
            android:text="הגדרות התרעות" android:textSize="16sp"
            android:backgroundTint="#333366" android:textColor="#FFFFFF"
            android:layout_marginBottom="28dp" />

        <View android:layout_width="340dp" android:layout_height="1dp"
            android:background="#444444" android:layout_marginBottom="20dp" />

        <!-- ── Test buttons ── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="בדיקות חיות" android:textColor="#888888"
            android:textSize="13sp" android:layout_marginBottom="10dp" />

        <!-- Pre-alert -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="התרעה מוקדמת (cat 14)" android:textColor="#F9A825"
            android:textSize="12sp" android:layout_marginBottom="4dp" />

        <Button android:id="@+id/btn_test_pre_general"
            android:layout_width="340dp" android:layout_height="wrap_content"
            android:text="TEST — מוקדמת כללית" android:textSize="15sp"
            android:backgroundTint="#E65100" android:textColor="#FFFFFF"
            android:layout_marginBottom="6dp" />

        <Button android:id="@+id/btn_test_pre_jerusalem"
            android:layout_width="340dp" android:layout_height="wrap_content"
            android:text="TEST — מוקדמת ירושלים" android:textSize="15sp"
            android:backgroundTint="#BF360C" android:textColor="#FFFFFF"
            android:layout_marginBottom="14dp" />

        <!-- Enter shelter -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="כניסה לממד (cat 1)" android:textColor="#E91E8C"
            android:textSize="12sp" android:layout_marginBottom="4dp" />

        <Button android:id="@+id/btn_test_general"
            android:layout_width="340dp" android:layout_height="wrap_content"
            android:text="TEST — כניסה לממד כללי" android:textSize="15sp"
            android:backgroundTint="#880E4F" android:textColor="#FFFFFF"
            android:layout_marginBottom="6dp" />

        <Button android:id="@+id/btn_test_jerusalem"
            android:layout_width="340dp" android:layout_height="wrap_content"
            android:text="TEST — כניסה לממד ירושלים" android:textSize="15sp"
            android:backgroundTint="#6A1B9A" android:textColor="#FFFF00"
            android:layout_marginBottom="14dp" />

        <!-- All clear -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="סיום / ניתן לצאת (cat 13)" android:textColor="#4CAF50"
            android:textSize="12sp" android:layout_marginBottom="4dp" />

        <Button android:id="@+id/btn_test_clear_general"
            android:layout_width="340dp" android:layout_height="wrap_content"
            android:text="TEST — סיום כללי" android:textSize="15sp"
            android:backgroundTint="#2E7D32" android:textColor="#FFFFFF"
            android:layout_marginBottom="6dp" />

        <Button android:id="@+id/btn_test_clear_jerusalem"
            android:layout_width="340dp" android:layout_height="wrap_content"
            android:text="TEST — סיום ירושלים" android:textSize="15sp"
            android:backgroundTint="#1B5E20" android:textColor="#98FF98"
            android:layout_marginBottom="14dp" />

        <!-- Hide -->
        <Button android:id="@+id/btn_test_hide"
            android:layout_width="340dp" android:layout_height="wrap_content"
            android:text="הסתר התרעה" android:textSize="15sp"
            android:backgroundTint="#333333" android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>
