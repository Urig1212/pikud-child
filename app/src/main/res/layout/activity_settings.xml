<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="64dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="הגדרות התרעות"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="40dp" />

        <!-- ── General alerts toggle ───────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#2A2A2A"
            android:padding="24dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="התרעות כלליות (שאר הארץ)"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_general_desc"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#AAAAAA"
                    android:textSize="15sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switch_general_alerts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:scaleX="1.4"
                android:scaleY="1.4"
                android:thumbTint="#E91E8C"
                android:trackTint="#7B1FA2" />
        </LinearLayout>

        <!-- ── City picker ─────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#2A2A2A"
            android:padding="24dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="הישוב שלי"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="התרעה על הישוב הזה תוצג בצורה בולטת עם הודעה אישית"
                android:textColor="#AAAAAA"
                android:textSize="15sp"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_current_city"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#E91E8C"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btn_pick_city"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="שנה ישוב"
                    android:textSize="16sp"
                    android:backgroundTint="#7B1FA2"
                    android:textColor="#FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── Personal message ────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#2A2A2A"
            android:padding="24dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="הודעה אישית בזמן התרעה"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="תוצג כאשר יש התרעה על הישוב שלך. ריק = הודעה ברירת מחדל"
                android:textColor="#AAAAAA"
                android:textSize="15sp"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/et_personal_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="למשל: כולם לממד עכשיו!"
                android:textColor="#FFFFFF"
                android:textColorHint="#666666"
                android:backgroundTint="#444444"
                android:textSize="18sp"
                android:padding="12dp"
                android:inputType="text" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="התרעות על הישוב שלך — תמיד יוצגות"
            android:textColor="#555555"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>
